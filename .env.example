# ── Shared socket settings for TS + Rust runtimes ─────────────
# Copy to .env and adjust once for all services.
# If running services without sudo and /run is not writable, override to a user-writable path.

# Optional: KAIROS_ENCLAVE_SOCKET=unix:///tmp/kairos-runtime-enclave.sock
# Optional: KAIROS_VFS_SOCKET=unix:///tmp/kairos-runtime-vfs.sock
KAIROS_ENCLAVE_SOCKET=unix:///run/kairos-runtime/sockets/kairos-runtime-enclave.sock
KAIROS_VFS_SOCKET=unix:///run/kairos-runtime/sockets/kairos-runtime-vfs.sock

# ── Cloud/Bot credentials ─────────────────────────────────────
ENCLAVE_API_KEY=your_api_key
CLOUD_API_KEY=your_api_key
BOT_TOKEN=your_bot_token
# Optional: OWNER_USER_ID=your_owner_user_id

# If you are running ollama on your host, use this value.
# Otherwise, use the default value in the docker-compose.yml file.
OLLAMA_BASE_URL=http://127.0.0.1:11434
# Optional: VFS_READY_TIMEOUT_SEC=1800

# ── Bench-runner (agent) ──────────────────────────────────────
# Primary model
API_KEY=your_api_key
MODEL=claude-opus-4.6-1m
# API_PROVIDER=anthropic                # auto-detected from MODEL
# BASE_URL=https://api.openai.com/v1    # auto-detected per provider

# Agent settings
# LOGOS_SOCKET=/opt/logos/state/sandbox/logos.sock  # set by harness
# AGENT_CONFIG=bench-runner
# MAX_TURNS=500
# ANTHROPIC_MAX_TOKENS=65536
# CONTEXT_LIMIT=1000000                 # auto-detected from MODEL
# EVAL_RETRIES=3                        # 0 to disable evaluator
# OPENAI_API_MODE=chat                  # "chat" | "responses" (auto for codex)

# ── Bench-runner (evaluator / cross-validation) ───────────────
EVALUATOR_MODEL=gpt-5.3-codex
EVALUATOR_API_KEY=your_openai_api_key
# EVALUATOR_API_PROVIDER=openai         # auto-detected from EVALUATOR_MODEL
# EVALUATOR_BASE_URL=https://api.openai.com/v1

# ── Agent install (terminal-bench harness) ────────────────────
# Host used to rewrite `archive.ubuntu.com` / `security.ubuntu.com` in task
# containers at agent setup. Defaults to `azure.archive.ubuntu.com`.
# Set to empty string to keep the image's original sources.
# Examples:
#   APT_MIRROR_HOST=azure.archive.ubuntu.com
#   APT_MIRROR_HOST=mirrors.tuna.tsinghua.edu.cn/ubuntu
#   APT_MIRROR_HOST=                      # disable rewrite
# APT_MIRROR_HOST=azure.archive.ubuntu.com
